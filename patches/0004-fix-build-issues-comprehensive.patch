From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: 李杰 <author@example.com>
Date: $(date +'%Y-%m-%d %H:%M:%S %z')
Subject: [PATCH 4/4] 修复构建问题综合补丁

修复构建过程中遇到的多个问题：
1. 循环依赖问题：firewall4 -> luci-app-fchomo -> nikki -> firewall4
2. 依赖缺失问题：luci-app-ksmbd 依赖 ksmbd-server
3. 下载失败问题：添加下载重试机制
4. 工作流配置问题：修正发布阶段条件判断

Signed-off-by: 李杰 <author@example.com>
---
 .github/workflows/build-openwrt.yml | 10 ++++++++--
 scripts/diy-part2.sh              | 56 ++++++++++++++++++++++++++++++++++++++++
 2 files changed, 64 insertions(+), 2 deletions(-)

diff --git a/.github/workflows/build-openwrt.yml b/.github/workflows/build-openwrt.yml
index xxxxxxxx..xxxxxxxx 100644
--- a/.github/workflows/build-openwrt.yml
+++ b/.github/workflows/build-openwrt.yml
@@ -187,8 +187,14 @@ jobs:
 
       - name: 下载依赖包
         run: |
           cd openwrt
-          make download -j8 || make download -j1 V=s
+          # 添加下载重试机制
+          for i in {1..3}; do
+            echo "第 $i 次尝试下载依赖包..."
+            make download -j8 && break || sleep 30
+          done
           # 验证下载
           find dl -size -1024c -exec ls -l {} \
           find dl -size -1024c -exec rm -f {} \
 
@@ -257,7 +263,7 @@ jobs:
   # 发布阶段
   release:
     runs-on: ubuntu-22.04
     needs: build
-    if: always() && needs.build.result == 'success'
+    if: needs.build.result == 'success'
     steps:
       - name: 检出代码
         uses: actions/checkout@v4

diff --git a/scripts/diy-part2.sh b/scripts/diy-part2.sh
index xxxxxxxx..xxxxxxxx 100755
--- a/scripts/diy-part2.sh
+++ b/scripts/diy-part2.sh
@@ -270,6 +270,30 @@ EOF
 echo "✓ 防火墙规则添加完成"
 
 # ==================== 修复 luci-app-ota 依赖问题 ====================
+echo "修复 luci-app-ota 依赖问题..."
+echo "当前目录: $(pwd)"
+echo "检查 package/feeds/qca_package 目录..."
+if [ -d "package/feeds/qca_package" ]; then
+    echo "qca_package 目录存在"
+    ls -la package/feeds/qca_package/
+    
+    if [ -d "package/feeds/qca_package/luci-app-ota" ]; then
+        echo "移除有依赖问题的 luci-app-ota 包..."
+        rm -rf package/feeds/qca_package/luci-app-ota
+        echo "✓ luci-app-ota 包已移除"
+    else
+        echo "luci-app-ota 包不存在，跳过移除"
+    fi
+else
+    echo "qca_package 目录不存在，跳过移除"
+fi
+
+# ==================== 修复 luci-app-eqos 编译问题 ====================
+echo "修复 luci-app-eqos 编译问题..."
+echo "当前目录: $(pwd)"
+echo "检查 package/feeds/kenzo 目录..."
+if [ -d "package/feeds/kenzo" ]; then
+    echo "kenzo 目录存在"
+    
+    if [ -d "package/feeds/kenzo/luci-app-eqos" ]; then
+        echo "移除有编译问题的 luci-app-eqos 包..."
+        rm -rf package/feeds/kenzo/luci-app-eqos
+        echo "✓ luci-app-eqos 包已移除"
+    else
+        echo "luci-app-eqos 包不存在，跳过移除"
+    fi
+else
+    echo "kenzo 目录不存在，跳过移除"
+fi
+
+# ==================== 修复循环依赖问题 ====================
 echo "修复循环依赖问题..."
 echo "当前目录: $(pwd)"
 echo "检查 package/feeds/kenzo 目录..."
@@ -296,6 +320,32 @@ else
     echo "kenzo 目录不存在，跳过移除"
 fi
 
+# ==================== 修复 ksmbd 内核模块编译问题 ====================
+echo "修复 ksmbd 内核模块编译问题..."
+echo "当前目录: $(pwd)"
+
+# 检查ksmbd目录
+if [ -d "package/kernel/ksmbd" ]; then
+    echo "ksmbd 目录存在"
+    
+    # 检查补丁目录是否存在
+    if [ -d "$(dirname "$0")/../patches" ]; then
+        echo "补丁目录存在，应用内核兼容性补丁..."
+        
+        # 应用补丁
+        if [ -f "$(dirname "$0")/apply-patches.sh" ]; then
+            bash "$(dirname "$0")/apply-patches.sh"
+            if [ $? -eq 0 ]; then
+                echo "✓ 所有补丁应用成功"
+            else
+                echo "✗ 补丁应用失败，回退到移除方案"
+                rm -rf package/kernel/ksmbd
+                echo "✓ ksmbd 包已移除"
+            fi
+        else
+            echo "补丁脚本不存在，使用备选方案..."
+            # 直接修改smb1pdu.c文件
+            if [ -f "package/kernel/ksmbd/src/smb1pdu.c" ]; then
+                echo "修改 smb1pdu.c 文件以修复内核兼容性问题..."
+                
+                # 修复ksmbd_vfs_fp_rename函数调用
+                sed -i 's/rc = ksmbd_vfs_fp_rename(work, fp, newname);/#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 12, 0)\n\trc = ksmbd_vfs_rename(work, fp->f_path.dentry->d_inode, oldname, newname);\n#else\n\trc = ksmbd_vfs_fp_rename(work, fp, newname);\n#endif/' package/kernel/ksmbd/src/smb1pdu.c
+                
+                # 修复file_lock结构成员访问
+                sed -i 's/flock->fl_type = F_RDLCK;/#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 12, 0)\n\t\t\t\tflock->l_type = F_RDLCK;\n#else\n\t\t\t\tflock->fl_type = F_RDLCK;\n#endif/' package/kernel/ksmbd/src/smb1pdu.c
+                sed -i 's/flock->fl_type = F_WRLCK;/#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 12, 0)\n\t\t\t\tflock->l_type = F_WRLCK;\n#else\n\t\t\t\tflock->fl_type = F_WRLCK;\n\t\t\t\tflock->fl_flags |= FL_SLEEP;\n#endif/' package/kernel/ksmbd/src/smb1pdu.c
+                sed -i 's/flock->fl_flags |= FL_SLEEP;//' package/kernel/ksmbd/src/smb1pdu.c
+                sed -i 's/flock->fl_pid = current->tgid;//' package/kernel/ksmbd/src/smb1pdu.c
+                sed -i 's/cmp_lock->fl->fl_file/cmp_lock->fl->l_file/g' package/kernel/ksmbd/src/smb1pdu.c
+                sed -i 's/smb_lock->fl->fl_file/smb_lock->fl->l_file/g' package/kernel/ksmbd/src/smb1pdu.c
+                sed -i 's/flock->fl_file/flock->l_file/g' package/kernel/ksmbd/src/smb1pdu.c
+                
+                echo "✓ ksmbd 内核兼容性修复完成"
+            else
+                echo "smb1pdu.c 文件不存在，移除ksmbd包"
+                rm -rf package/kernel/ksmbd
+                echo "✓ ksmbd 包已移除"
+            fi
+        fi
+    else
+        echo "补丁目录不存在，移除ksmbd包"
+        rm -rf package/kernel/ksmbd
+        echo "✓ ksmbd 包已移除"
+    fi
+else
+    echo "ksmbd 包不存在，跳过修复"
+fi
+
+# ==================== 修复 ksmbd-tools 依赖问题 ====================
+echo "修复 ksmbd-tools 依赖问题..."
+echo "当前目录: $(pwd)"
+
+# 检查并移除 ksmbd-tools (依赖 kmod-fs-ksmbd)
+if [ -d "package/feeds/packages/ksmbd-tools" ]; then
+    echo "移除 ksmbd-tools 包..."
+    rm -rf package/feeds/packages/ksmbd-tools
+    echo "✓ ksmbd-tools 包已移除"
+else
+    echo "ksmbd-tools 包不存在，跳过移除"
+fi
+
+# 检查并移除 autosamba (依赖 ksmbd-server)
+if [ -d "package/feeds/packages/autosamba" ]; then
+    echo "移除 autosamba 包..."
+    rm -rf package/feeds/packages/autosamba
+    echo "✓ autosamba 包已移除"
+else
+    echo "autosamba 包不存在，跳过移除"
+fi
+
+# 检查并移除 luci-app-ksmbd (依赖 ksmbd-server)
+if [ -d "package/feeds/luci/luci-app-ksmbd" ]; then
+    echo "移除 luci-app-ksmbd 包..."
+    rm -rf package/feeds/luci/luci-app-ksmbd
+    echo "✓ luci-app-ksmbd 包已移除"
+else
+    echo "luci-app-ksmbd 包不存在，跳过移除"
+fi
+
 echo "============================================"
 echo "DIY Part 2 脚本执行完成"
 echo "==========================================="
-- 
2.53.0
