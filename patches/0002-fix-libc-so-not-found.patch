From: 李杰 <author@example.com>
Date: Sun, 30 Mar 2026 00:00:00 +0800
Subject: [PATCH] fix: libc.so not found issue during compilation

Fix libc.so not found error during compilation by:
1. Ensuring proper library path configuration
2. Fixing samba library linking

Signed-off-by: 李杰 <author@example.com>
---
 package/network/services/samba4/Makefile | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/package/network/services/samba4/Makefile b/package/network/services/samba4/Makefile
index xxxxxxx..xxxxxxx 100644
--- a/package/network/services/samba4/Makefile
+++ b/package/network/services/samba4/Makefile
@@ -1,6 +1,16 @@
 include $(TOPDIR)/rules.mk
 
 PKG_NAME:=samba4
+PKG_RELEASE:=1
+
+# Fix libc.so not found issue
+ifeq ($(CONFIG_USE_MUSL),y)
+  TARGET_LIBC_PATH:=$(STAGING_DIR)/target-$(ARCH_PACKAGES)/root-$(BOARD)/lib
+else
+  TARGET_LIBC_PATH:=$(STAGING_DIR)/target-$(ARCH_PACKAGES)/root-$(BOARD)/usr/lib
+endif
+
+# Add libc path to linker flags
+TARGET_LDFLAGS += -Wl,-rpath-link=$(TARGET_LIBC_PATH)
 
 PKG_VERSION:=4.18.12
 PKG_RELEASE:=1
@@ -10,6 +20,7 @@ PKG_SOURCE_URL:=https://download.samba.org/pub/samba/stable
 PKG_HASH:=c2b5c7f3a5a9f8a4c9a7c9c0c9c0c9c0c9c0c9c0c9c0c9c0c9c0c9c0c9c0c9c0
 
 include $(INCLUDE_DIR)/package.mk
+include $(INCLUDE_DIR)/kernel.mk
 
 define Package/samba4
   SECTION:=net
-- 
